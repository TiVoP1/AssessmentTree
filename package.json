{
  "name": "property-manager-api",
  "version": "1.0.0",
  "description": "GraphQL API for property management with Weatherstack integration",
  "type": "module",
  "imports": {
    "#src/*": {
      "development": "./src/*",
      "default": "./dist/*"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "node --conditions development --import tsx --watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "lint": "eslint src/ __tests__/",
    "lint:fix": "eslint src/ __tests__/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"__tests__/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"__tests__/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:test": "dotenv -e .env.test -- prisma migrate deploy",
    "db:seed:dev": "tsx src/db/seed-dev.ts",
    "db:reset": "tsx src/db/reset.ts",
    "db:reset:dev": "pnpm db:reset && pnpm db:seed:dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "docker:up": "docker compose up -d --wait",
    "docker:down": "docker compose down",
    "init:dev": "pnpm docker:up && pnpm db:generate && pnpm db:migrate:dev && pnpm db:migrate:test && pnpm db:seed:dev"
  },
  "dependencies": {
    "@apollo/server": "^5.5.0",
    "@as-integrations/express5": "^1.1.2",
    "@prisma/client": "^6.5.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "graphql": "^16.10.0",
    "graphql-scalars": "^1.24.0",
    "zod": "^3.24.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "@apollo/protobufjs"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.10",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-n": "^17.16.2",
    "eslint-plugin-unused-imports": "^4.1.4",
    "prettier": "^3.5.3",
    "prisma": "^6.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.9"
  }
}
